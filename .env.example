# Empathic Memory Bench — API keys
#
# Copy to `.env` and fill in your keys, OR provision them as
# ~/.openclaw/secrets/<filename> (one key per file) if you prefer.
# The scripts try the file path first, then fall back to these env vars.
#
# Only the keys you need for the benchmarks you're running are required:
#  - bench v3 (empathic memory): OpenAI embed, Cohere embed (for LongMemEval/LOCOMO),
#    plus at least one judge provider
#  - LongMemEval / ES-MemEval: Cohere embed + chosen QA provider
#  - LOCOMO: Cohere embed + chosen QA provider

# ---- Embeddings ----

# Cohere embed-v4.0 (used by bench v3 and all external benchmarks)
# Get it at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# OpenAI (text-embedding-3-large for Pulse v2_pure native embeddings)
# Get it at: https://platform.openai.com/api-keys
# Also used as a judge (gpt-5.4)
OPENAI_API_KEY=

# ---- Judges / QA providers ----

# Moonshot — Kimi K2.6 + Kimi K2-0711-preview
# Get it at: https://platform.moonshot.ai/console
MOONSHOT_API_KEY=

# Z.ai — GLM-5 + GLM-5.1
# Get it at: https://z.ai/
ZAI_API_KEY=

# Alibaba DashScope — Qwen3-Max + DeepSeek V3.2 (shared endpoint)
# Get it at: https://dashscope-intl.aliyuncs.com/
DASHSCOPE_API_KEY=

# Anthropic — Claude Opus 4.7 (only needed if you want Opus as API judge;
# our 8-judge run used Opus-in-chat via Claude Code, free)
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ---- Optional ----

# xAI Grok — currently not used (access denied 2026-04-24).
# Left here in case future versions add Grok.
# X_AI_API_KEY=
